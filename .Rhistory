# R Basics - day thirteen
rm(list=ls())
#%%%%%%%%%%%%%%%%%%% Regresssion Analysis %%%%%%%%%%%%%%%%%%%%
# Load Required Libraries
library(stats)    # For lm(), glm(), and arima()
library(datasets) # For mtcars, AirPassengers
library(forecast) # For ARIMA modeling
library(ISLR)     # For Credit dataset
## (y-binary - 0 or 1) = \alpha + \beta_1
data("Credit")
# since we model one hypothesis - married with certain age, income and balance
# we create marrried_target binary variable
credit_dat <- Credit
credit_dat$marriedTargtet <- ifelse(credit_dat$Married == "Yes",1,0)
head(credit_dat)
# Fit logistic regression model ----
log_reg <- glm(marriedTargtet ~ Income + Balance +Age ,
family = binomial(link = "logit"), data = credit_dat)
#### note: character used for column names(variable names) are strings but not necessarily
#### dealth with doubt quote, its use is for values
log_reg
summary(log_reg)
# Time Series ARIMA, ARDL ,  VAR ----
## ARIMA = auto regressive integrated moving average
## y= \alpha + \beta_1 y_t-1
## ARDL = distributed lag
## VAR = vector auto regressive
## SVAR = Structurral + VAR , VAR = Macro
## We will do Airpassenger dataset for ARIMA - 1949-60. monthly time series
plot(AirPassengers)
# Time Series ARIMA, ARDL ,  VAR ----
## ARIMA = auto regressive integrated moving average
## y= \alpha + \beta_1 y_t-1
## ARDL = distributed lag
## VAR = vector auto regressive
## SVAR = Structurral + VAR , VAR = Macro
## We will do Airpassenger dataset for ARIMA - 1949-60. monthly time series
plot(AirPassengers,
main= "Air passenger number across months",
xlab = "Years",
ylab = "number of passengers")
# Fit ARIMA model (auto.arima selects optimal parameters)
arima_model <- forecast::auto.arima(AirPassengers)
summary(arima_model)
## note : difference concept - t - (t-1) = \delta t
arima_forecast <- forecast::forecast(arima_model,h=12)
plot(arim)
plot(arima_forecast)
plot(arima_forecast)
View(credit_dat)
# R Basics - day thirteen
rm(list=ls())
#%%%%%%%%%%%%%%%%%%% Regresssion Analysis %%%%%%%%%%%%%%%%%%%%
# Load Required Libraries
library(stats)    # For lm(), glm(), and arima()
library(datasets) # For mtcars, AirPassengers
library(forecast) # For ARIMA modeling
library(ISLR)     # For Credit dataset
## (y-binary - 0 or 1) = \alpha + \beta_1
data("Credit")
# since we model one hypothesis - married with certain age, income and balance
# we create marrried_target binary variable
credit_dat <- Credit
credit_dat$marriedTargtet <- ifelse(credit_dat$Married == "Yes",1,0)
head(credit_dat)
# Fit logistic regression model ----
log_reg <- glm(marriedTargtet ~ Income + Balance +Age ,
family = binomial(link = "logit"), data = credit_dat)
#### note: character used for column names(variable names) are strings but not necessarily
#### dealth with doubt quote, its use is for values
log_reg
summary(log_reg)
# Time Series ARIMA, ARDL ,  VAR ----
## ARIMA = auto regressive integrated moving average
## y= \alpha + \beta_1 y_t-1 +n \beta_2. y_t-2
## ARDL = distributed lag
## VAR = vector auto regressive
## SVAR = Structurral + VAR , VAR = Macro
## We will do Airpassenger dataset for ARIMA - 1949-60. monthly time series
plot(AirPassengers,
main= "Air passenger number across months",
xlab = "Years",
ylab = "number of passengers")
# Fit ARIMA model (auto.arima selects optimal parameters)
arima_model <- forecast::auto.arima(AirPassengers)
summary(arima_model)
## note : difference concept - t - (t-1) = \delta t
arima_forecast <- forecast::forecast(arima_model,h=12)
plot(arima_forecast)
