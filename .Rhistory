# R Basics - day thirteen
rm(list=ls())
library(dplyr)
library(ggplot2)
library(readr)
car_dat <- read.csv("~/Documents/GRIT/GRITmay/data/car data.csv")
names(car_dat)
## Descriptive , more empirical
# T test -----
t_test_result <- t.test(Selling_Price~Transmission,data=car_dat)
t_test_result
names(car_dat)
# ANOVA -----
anova_result <- aov(Selling_Price ~ Fuel_Type, data = car_dat)
anova_result
summary(anova_result) #to check if result is significant
# Post hoc Test ---
TukeyHSD(anova_result)
# Visualizations ----
# Boxplot for T-test variable
boxplot(Selling_Price ~ Transmission, data = car_data,
main = "Selling Price by Transmission",
xlab = "Transmission", ylab = "Selling Price",
col = "lightblue")
# Visualizations ----
# Boxplot for T-test variable
boxplot(Selling_Price ~ Transmission, data = car_dat,
main = "Selling Price by Transmission",
xlab = "Transmission", ylab = "Selling Price",
col = "lightblue")
# Boxplot for Anova
boxplot(Selling_Price ~ Fuel_Type, data = car_data,
main = "Selling Price by Transmission",
xlab = "Transmission", ylab = "Selling Price",
col = "lightblue")
# Boxplot for Anova
boxplot(Selling_Price ~ Fuel_Type, data = car_dat,
main = "Selling Price by Transmission",
xlab = "Transmission", ylab = "Selling Price",
col = "lightblue")
# Boxplot for T-test variable
boxplot(Selling_Price ~ Present_Price, data = car_data,
main = "Selling Price by Transmission",
xlab = "Transmission", ylab = "Selling Price",
col = "lightblue")
# Boxplot for T-test variable
boxplot(Selling_Price ~ Present_Price, data = car_dat,
main = "Selling Price by Transmission",
xlab = "Transmission", ylab = "Selling Price",
col = "lightblue")
# Boxplot for Anova
boxplot(Selling_Price ~ Fuel_Type, data = car_dat,
col = "lightblue")
# Boxplot for T-test variable
boxplot(Selling_Price ~ Present_Price, data = car_dat,
main = "Selling Price and Present Price",
xlab = "Selling Price", ylab = "Present Price",
col = "lightblue")
