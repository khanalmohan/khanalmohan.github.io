lin_reg
summary(lin_reg)
# Fit linear regreesion model ----
lin_reg <- lm(mpg ~ hp + wt + am, data= mtcars)
summary(lin_reg)
## mpg(y) = \aplha + \beta_1 hp + \beta_2 wt + \beta_3 am +\epsilon
summary(lin_reg)
